#!/bin/bash
# Reminds contributors to process friction files before they pile up.

FRICTION_DIR=".claude/friction"
COUNT=$(find "$FRICTION_DIR" -name "*.md" 2>/dev/null | wc -l)

if [ "$COUNT" -gt 0 ]; then
  echo "Push blocked: $COUNT friction file(s) captured in .claude/friction/. Run /improve-docs to help improve the repository docs, or use --no-verify to skip." >&2
  exit 1
fi
