{
  "enabledPlugins": {
    "togi@togi": true
  },
  "extraKnownMarketplaces": {
    "togi": {
      "source": {
        "source": "github",
        "repo": "gwenneg/togi"
      },
      "autoUpdate": true
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/bin/togi remind",
            "timeout": 2000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/bin/togi capture",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
